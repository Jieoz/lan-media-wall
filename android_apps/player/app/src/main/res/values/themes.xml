<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base app theme (settings screen) -->
    <style name="Theme.Player" parent="Theme.AppCompat.DayNight">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Fullscreen kiosk theme: no action bar, black background, fullscreen.
         Immersive flags are also set programmatically in MainActivity so the
         system bars stay hidden after transient swipes (§11). -->
    <style name="Theme.Player.Fullscreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

</resources>
