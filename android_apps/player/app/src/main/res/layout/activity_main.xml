<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Video uses SurfaceView so HiSilicon hardware decode can take the HWC
         overlay path instead of compositing every frame through Mali/TextureView. -->
    <SurfaceView
        android:id="@+id/video_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Image surface (§6.1 type=="image"). ExoPlayer can't render a still, so
         image playlist items draw here, above the video surface. Hidden while
         video plays; shown (video paused) while an image is on screen. -->
    <ImageView
        android:id="@+id/player_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="@string/idle_text" />

    <!-- Idle / stop placeholder: pure black with a faint label. Shown above
         the surface when nothing plays so the desktop is never visible (§11). -->
    <FrameLayout
        android:id="@+id/idle_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible">

        <ImageView
            android:id="@+id/idle_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@string/idle_text" />

        <TextView
            android:id="@+id/idle_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/idle_text"
            android:textColor="@color/idle_text"
            android:textSize="18sp" />
    </FrameLayout>

</FrameLayout>
