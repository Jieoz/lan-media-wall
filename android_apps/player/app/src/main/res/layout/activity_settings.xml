<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:paddingBottom="16dp" />

        <!-- §4.2/§7 first-boot notice: must open once manually (stopped-state
             rule) + LAN-only warning. Shown big at the top so it isn't missed. -->
        <TextView
            android:id="@+id/text_first_boot_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/first_boot_notice"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:paddingBottom="16dp" />

        <!-- §2 zero-config status: LAN IP / device_id / group so the operator
             can eyeball-verify this box before pairing. -->
        <TextView
            android:id="@+id/text_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <!-- §2 一眼可核对: connection status + hardware self-check + junk-package
             warning, grouped at the top so a screenshot tells the whole story. -->
        <TextView style="@style/SettingLabel" android:text="@string/label_conn_status" />
        <TextView
            android:id="@+id/text_conn_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView style="@style/SettingLabel" android:text="@string/label_hardware" />
        <TextView
            android:id="@+id/text_hardware"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView style="@style/SettingLabel" android:text="@string/label_bloatware" />
        <TextView
            android:id="@+id/text_bloatware"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <TextView style="@style/SettingLabel" android:text="@string/label_diag_status" />
        <TextView
            android:id="@+id/text_diag_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <TextView
            android:id="@+id/text_diag_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/idle_text"
            android:textSize="12sp"
            android:paddingBottom="8dp" />
        <TextView
            android:id="@+id/text_diag_helper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="2dp" />
        <TextView
            android:id="@+id/text_diag_restart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="2dp" />
        <TextView
            android:id="@+id/text_diag_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="2dp" />
        <TextView
            android:id="@+id/text_diag_playback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="2dp" />
        <TextView
            android:id="@+id/text_diag_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="2dp" />
        <TextView
            android:id="@+id/text_diag_errors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingBottom="8dp" />
        <TextView
            android:id="@+id/text_diag_probe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/idle_text"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btn_refresh_diag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_refresh_diag" />

        <TextView style="@style/SettingLabel" android:text="@string/label_device_name" />
        <EditText
            android:id="@+id/input_device_name"
            style="@style/SettingInput"
            android:hint="@string/hint_device_name"
            android:inputType="text" />

        <TextView style="@style/SettingLabel" android:text="@string/label_broker_host" />
        <EditText
            android:id="@+id/input_broker_host"
            style="@style/SettingInput"
            android:hint="@string/hint_broker_host"
            android:inputType="text" />

        <TextView style="@style/SettingLabel" android:text="@string/label_broker_port" />
        <EditText
            android:id="@+id/input_broker_port"
            style="@style/SettingInput"
            android:hint="@string/hint_broker_port"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/input_use_wss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="@string/label_use_wss" />

        <TextView style="@style/SettingLabel" android:text="@string/label_group_id" />
        <EditText
            android:id="@+id/input_group_id"
            style="@style/SettingInput"
            android:hint="@string/hint_group_id"
            android:inputType="text" />

        <TextView style="@style/SettingLabel" android:text="@string/label_psk" />
        <EditText
            android:id="@+id/input_psk"
            style="@style/SettingInput"
            android:hint="@string/hint_psk"
            android:inputType="textPassword" />

        <CheckBox
            android:id="@+id/input_always_thumbs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="@string/label_always_thumbs" />

        <!-- §backend-ab: pick the video playback kernel. `auto` keeps the
             legacy-stable default (ExoPlayer); `mediaplayer` is the native
             android.media.MediaPlayer path for the HiSilicon boxes. Explicit
             + observable so an operator can A/B on the real box. -->
        <TextView style="@style/SettingLabel" android:text="@string/label_video_backend" />
        <TextView
            android:id="@+id/text_video_backend_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hint_video_backend"
            android:textColor="@color/idle_text"
            android:textSize="12sp"
            android:paddingBottom="4dp" />
        <RadioGroup
            android:id="@+id/group_video_backend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/backend_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="@string/backend_auto" />
            <RadioButton
                android:id="@+id/backend_exoplayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="@string/backend_exoplayer" />
            <RadioButton
                android:id="@+id/backend_mediaplayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="@string/backend_mediaplayer" />
        </RadioGroup>

        <!-- §1 configuration reversal: this camera-less TV box no longer scans.
             It DISPLAYS its own enrollment QR (built by QrEncoder) so the phone
             controller scans it. Shown with the LAN connection info below it. -->
        <TextView
            android:id="@+id/label_pair_qr"
            style="@style/SettingLabel"
            android:text="@string/label_pair_qr"
            android:layout_marginTop="24dp" />

        <ImageView
            android:id="@+id/image_pair_qr"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/white"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/label_pair_qr" />

        <TextView
            android:id="@+id/text_pair_uri"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/idle_text"
            android:textSize="11sp"
            android:paddingTop="8dp"
            android:gravity="center_horizontal" />

        <!-- §4.1 (v1.13.7+): the kiosk player IS the HOME/launcher — the HOME
             intent-filter lives on MainActivity, so there is no runtime toggle
             here. This box is a dedicated media wall; grabbing HOME is intended. -->

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_save" />

        <!-- §9 self-recovery: clear broker config back to zero-config / QR
             pairing without adb. Sits below Save; confirms before wiping. -->
        <Button
            android:id="@+id/btn_reset_conn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_reset_conn" />

    </LinearLayout>
</ScrollView>
